# OSM Counter NG — Environment Variables Reference
#
# Copy this file to .env.local and fill in your values:
# cp env.example .env
#
# For Vercel: Add these in Project Settings → Environment Variables

VITE_SUPABASE_URL=https://eljlxaowizfjmpndmsqc.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Explicit storage URL (will be derived from VITE_SUPABASE_URL if not set)
# VITE_SUPABASE_STORAGE_URL=https://eljlxaowizfjmpndmsqc.supabase.co/storage/v1/object/public/ef

# Optional: Banner image filename in Supabase storage (defaults to Gemini_Generated_Image_3q1iy3q1iy3q1iy3.png)
# VITE_SUPABASE_BANNER_IMAGE=your-banner-image.png
